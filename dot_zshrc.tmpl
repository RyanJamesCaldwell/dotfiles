# Optional one-shot startup profiling: run `zsh-startup-profile` after login.
if [[ -n "${ZSH_STARTUP_PROFILE:-}" ]]; then
  zmodload zsh/zprof
fi

_value_in_list() {
  local needle="$1"
  shift
  local value
  for value in "$@"; do
    [[ "$value" == "$needle" ]] && return 0
  done
  return 1
}

_pick_from_values() {
  local prompt="$1"
  shift
  local -a choices
  choices=("$@")

  if (( ${#choices[@]} == 0 )); then
    echo "No choices available for $prompt." >&2
    return 1
  fi

  if command -v fzf >/dev/null 2>&1; then
    printf '%s\n' "${choices[@]}" | fzf --prompt="${prompt}> " "--height=~40%" --layout=reverse --border
    return
  fi

  if [[ -t 0 && -t 1 ]]; then
    local i choice
    echo "fzf is unavailable; choose a $prompt:" >&2
    for (( i = 1; i <= ${#choices[@]}; i++ )); do
      echo "  $i) ${choices[$i]}" >&2
    done
    read "choice?$prompt number: " || return 1
    if [[ "$choice" == <-> && "$choice" -ge 1 && "$choice" -le ${#choices[@]} ]]; then
      printf '%s\n' "${choices[$choice]}"
      return 0
    fi
    echo "Invalid selection: $choice" >&2
    return 1
  fi

  echo "fzf is unavailable; run one of: ${choices[*]}" >&2
  return 1
}

_notify_terminal() {
  local title="$1"
  local message="$2"
  if command -v terminal-notifier >/dev/null 2>&1; then
    terminal-notifier -title "$title" -message "$message" >/dev/null 2>&1
  fi
}

zsh-startup-profile() {
  ZSH_STARTUP_PROFILE=1 zsh -i -c exit
}

# oh-my-zsh
CHEZMOI_PROFILE_CHOICES=(personal work)
if [[ -n "${CHEZMOI_PROFILE:-}" ]]; then
  profile="$CHEZMOI_PROFILE"
elif [[ -s "$HOME/.chezmoi_profile" ]]; then
  profile="$(<"$HOME/.chezmoi_profile")"
else
  profile="{{ .profile | default "personal" }}"
fi

if [[ -z "$profile" ]]; then
  profile="personal"
fi

export CHEZMOI_PROFILE="$profile"
_source_chezmoi_profile_overrides() {
  [[ -f "$HOME/.zshrc.${CHEZMOI_PROFILE}" ]] && source "$HOME/.zshrc.${CHEZMOI_PROFILE}"
}
_source_chezmoi_profile_overrides

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME=""
plugins=(git)
source $ZSH/oh-my-zsh.sh

export PNPM_HOME="$HOME/Library/pnpm/pnpm"
export BUN_INSTALL="$HOME/.bun"
export ASDF_DATA_DIR="${ASDF_DATA_DIR:-$HOME/.asdf}"
export NVM_DIR="${NVM_DIR:-$HOME/.nvm}"

_nvm_default_bin() {
  local alias_file="$NVM_DIR/alias/default"
  local version
  [[ -r "$alias_file" ]] || return 1
  IFS= read -r version < "$alias_file" || return 1
  [[ -n "$version" ]] || return 1

  case "$version" in
    v*) ;;
    [0-9]*) version="v$version" ;;
    *) return 1 ;;
  esac

  local bin_dir="$NVM_DIR/versions/node/$version/bin"
  if [[ -d "$bin_dir" ]]; then
    printf '%s\n' "$bin_dir"
    return 0
  fi

  local -a matches
  matches=("$NVM_DIR"/versions/node/"$version"*/bin(N))
  if (( ${#matches[@]} > 0 )); then
    printf '%s\n' "${matches[1]}"
    return 0
  fi

  return 1
}

NVM_DEFAULT_BIN="$(_nvm_default_bin)"
typeset -U path PATH
path=(
  $PNPM_HOME
  ${NVM_DEFAULT_BIN:+$NVM_DEFAULT_BIN}
  /opt/homebrew/bin
  /opt/homebrew/opt/curl/bin
  $HOME/.local/bin
  $HOME/go/bin
  $BUN_INSTALL/bin
  $ASDF_DATA_DIR/shims
  $path
)
export PATH
unset NVM_DEFAULT_BIN

_asdf_init_file() {
  if [[ -f /opt/homebrew/opt/asdf/libexec/asdf.sh ]]; then
    printf '%s\n' /opt/homebrew/opt/asdf/libexec/asdf.sh
    return 0
  fi

  if command -v brew >/dev/null 2>&1; then
    local asdf_prefix
    asdf_prefix="$(brew --prefix asdf 2>/dev/null)"
    if [[ -n "$asdf_prefix" && -f "$asdf_prefix/libexec/asdf.sh" ]]; then
      printf '%s\n' "$asdf_prefix/libexec/asdf.sh"
      return 0
    fi
  fi

  return 1
}

_load_asdf() {
  [[ -n "${__ASDF_LOADED:-}" ]] && return 0
  local asdf_script
  asdf_script="$(_asdf_init_file)" || return 1
  . "$asdf_script"
  __ASDF_LOADED=1
}

if [[ -f /opt/homebrew/opt/asdf/libexec/asdf.sh ]] || command -v asdf >/dev/null 2>&1; then
  asdf() {
    unfunction asdf 2>/dev/null || true
    _load_asdf >/dev/null 2>&1 || true
    asdf "$@"
  }
fi

set -o vi
tabs -2

# Shared theme selection for terminal + Neovim.
THEME_CHOICES=(sakura_night ashfall rosepine)
THEME_STATE_DIR="$HOME/.config/theme"
THEME_STATE_FILE="$THEME_STATE_DIR/current"
STARSHIP_THEME_DIR="$HOME/.config/starship/themes"
if [[ -r "$THEME_STATE_FILE" ]]; then
  export NVIM_THEME="$(<"$THEME_STATE_FILE")"
else
  export NVIM_THEME="sakura_night"
fi

_set_starship_config_for_theme() {
  local theme_name="$1"
  local config_path
  case "$theme_name" in
    sakura_night) config_path="$STARSHIP_THEME_DIR/sakura_night.toml" ;;
    ashfall) config_path="$STARSHIP_THEME_DIR/ashfall.toml" ;;
    rosepine) config_path="$STARSHIP_THEME_DIR/rosepine.toml" ;;
    *) config_path="$HOME/.config/starship.toml" ;;
  esac

  if [[ -r "$config_path" ]]; then
    export STARSHIP_CONFIG="$config_path"
  else
    export STARSHIP_CONFIG="$HOME/.config/starship.toml"
  fi
}

_set_starship_config_for_theme "$NVIM_THEME"

_is_valid_theme() {
  _value_in_list "$1" "${THEME_CHOICES[@]}"
}

_print_theme_usage() {
  echo "Usage: theme <sakura_night|ashfall|rosepine|current|list|pick>"
}

_sync_theme_from_state() {
  [[ -r "$THEME_STATE_FILE" ]] || return 0
  local saved
  saved="$(<"$THEME_STATE_FILE")"
  case "$saved" in
    sakura_night|ashfall|rosepine)
      if [[ "$saved" != "$NVIM_THEME" ]]; then
        export NVIM_THEME="$saved"
        _set_starship_config_for_theme "$NVIM_THEME"
      fi
      ;;
  esac
}

theme() {
  local action="${1:-current}"

  case "$action" in
    current)
      _sync_theme_from_state
      echo "Current theme: $NVIM_THEME"
      [[ $# -eq 0 ]] && _print_theme_usage
      return 0
      ;;
    list|ls)
      printf '%s\n' "${THEME_CHOICES[@]}"
      return 0
      ;;
    pick|select)
      local picked
      picked="$(_pick_from_values "Theme" "${THEME_CHOICES[@]}")" || return 1
      [[ -n "$picked" ]] || return 1
      theme "$picked"
      return $?
      ;;
    help|-h|--help)
      echo "Current theme: $NVIM_THEME"
      _print_theme_usage
      return 0
      ;;
  esac

  if ! _is_valid_theme "$action"; then
    echo "Invalid theme: $action" >&2
    echo "Valid themes: ${THEME_CHOICES[*]}" >&2
    return 1
  fi

  export NVIM_THEME="$action"
  _set_starship_config_for_theme "$NVIM_THEME"
  mkdir -p "$THEME_STATE_DIR"
  if ! printf '%s\n' "$action" > "$THEME_STATE_FILE"; then
    echo "Failed to write theme state to $THEME_STATE_FILE" >&2
    return 1
  fi
  echo "Theme set to $action"
}

_is_valid_chezmoi_profile() {
  _value_in_list "$1" "${CHEZMOI_PROFILE_CHOICES[@]}"
}

_print_profile_usage() {
  echo "Usage: profile <personal|work|current|list|pick>"
}

_set_chezmoi_profile() {
  local next="$1"

  if ! _is_valid_chezmoi_profile "$next"; then
    echo "Invalid profile: $next" >&2
    echo "Valid profiles: ${CHEZMOI_PROFILE_CHOICES[*]}" >&2
    return 1
  fi

  if ! printf '%s\n' "$next" > "$HOME/.chezmoi_profile"; then
    echo "Failed to write profile state to $HOME/.chezmoi_profile" >&2
    return 1
  fi

  export CHEZMOI_PROFILE="$next"

  if command -v chezmoi >/dev/null 2>&1; then
    if ! chezmoi apply; then
      _notify_terminal "Chezmoi profile" "Failed to apply profile $next"
      echo "Profile saved as $next, but 'chezmoi apply' failed." >&2
      return 1
    fi
  else
    echo "chezmoi not found; wrote $HOME/.chezmoi_profile but did not apply templates." >&2
  fi

  _notify_terminal "Chezmoi profile" "Profile set to $next"
  echo "Profile set to $next"
}

profile() {
  local action="${1:-current}"

  case "$action" in
    current)
      echo "Current profile: ${CHEZMOI_PROFILE:-unknown}"
      [[ $# -eq 0 ]] && _print_profile_usage
      return 0
      ;;
    list|ls)
      printf '%s\n' "${CHEZMOI_PROFILE_CHOICES[@]}"
      return 0
      ;;
    pick|select)
      local picked
      picked="$(_pick_from_values "Profile" "${CHEZMOI_PROFILE_CHOICES[@]}")" || return 1
      [[ -n "$picked" ]] || return 1
      profile "$picked"
      return $?
      ;;
    help|-h|--help)
      echo "Current profile: ${CHEZMOI_PROFILE:-unknown}"
      _print_profile_usage
      return 0
      ;;
  esac

  _set_chezmoi_profile "$action"
}

autoload -Uz add-zsh-hook
add-zsh-hook precmd _sync_theme_from_state

# Aliases
alias la='eza --long --all --git --no-user --icons=auto'
alias l='eza --long --git --no-user --icons=auto'
alias where='find . -name'
alias gd='git diff'
alias gs='git status'
alias gb='git branch'

if command -v fzf >/dev/null 2>&1; then
  source <(fzf --zsh)
fi
if [[ -s "$NVM_DIR/nvm.sh" ]]; then
  _load_nvm() {
    [[ -n "${__NVM_LOADED:-}" ]] && return 0
    unfunction nvm node npm npx yarn corepack 2>/dev/null || true
    . "$NVM_DIR/nvm.sh"
    [[ -s "$NVM_DIR/bash_completion" ]] && . "$NVM_DIR/bash_completion"
    __NVM_LOADED=1
  }

  nvm() {
    _load_nvm || return $?
    nvm "$@"
  }

  _nvm_lazy_command() {
    local command_name="$1"
    shift
    _load_nvm >/dev/null 2>&1 || true
    command "$command_name" "$@"
  }

  node() { _nvm_lazy_command node "$@"; }
  npm() { _nvm_lazy_command npm "$@"; }
  npx() { _nvm_lazy_command npx "$@"; }
  yarn() { _nvm_lazy_command yarn "$@"; }
  corepack() { _nvm_lazy_command corepack "$@"; }
fi
[[ -s "$HOME/.local/bin/env" ]] && source "$HOME/.local/bin/env"

export EDITOR='nvim'
[[ -s /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]] && \
  source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
[[ -s /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] && \
  source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
eval "$(starship init zsh)"

