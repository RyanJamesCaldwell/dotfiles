# oh-my-zsh
if [[ -n "${CHEZMOI_PROFILE:-}" ]]; then
  profile="$CHEZMOI_PROFILE"
elif [[ -s "$HOME/.chezmoi_profile" ]]; then
  profile="$(<"$HOME/.chezmoi_profile")"
else
  profile="{{ .profile | default "work" }}"
fi

if [[ -z "$profile" ]]; then
  profile="personal"
fi

export CHEZMOI_PROFILE="$profile"
[[ -f "$HOME/.zshrc.${CHEZMOI_PROFILE}" ]] && source "$HOME/.zshrc.${CHEZMOI_PROFILE}"

export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME=""
plugins=(git)
source $ZSH/oh-my-zsh.sh


if [ -f /opt/homebrew/opt/asdf/libexec/asdf.sh ]; then
  . /opt/homebrew/opt/asdf/libexec/asdf.sh
elif command -v brew >/dev/null 2>&1; then
  ASDF_PREFIX="$(brew --prefix asdf 2>/dev/null)"
  if [ -n "$ASDF_PREFIX" ] && [ -f "$ASDF_PREFIX/libexec/asdf.sh" ]; then
    . "$ASDF_PREFIX/libexec/asdf.sh"
  fi
  unset ASDF_PREFIX
fi

export PATH="/opt/homebrew/bin:/opt/homebrew/opt/curl/bin:$HOME/.local/bin:$PATH"
export PATH="$HOME/go/bin:$PATH"

set -o vi
tabs -2

# Shared theme selection for terminal + Neovim.
THEME_STATE_DIR="$HOME/.config/theme"
THEME_STATE_FILE="$THEME_STATE_DIR/current"
STARSHIP_THEME_DIR="$HOME/.config/starship/themes"
if [[ -r "$THEME_STATE_FILE" ]]; then
  export NVIM_THEME="$(<"$THEME_STATE_FILE")"
else
  export NVIM_THEME="sakura_night"
fi

_set_starship_config_for_theme() {
  local theme_name="$1"
  local config_path
  case "$theme_name" in
    sakura_night) config_path="$STARSHIP_THEME_DIR/sakura_night.toml" ;;
    ashfall) config_path="$STARSHIP_THEME_DIR/ashfall.toml" ;;
    rosepine) config_path="$STARSHIP_THEME_DIR/rosepine.toml" ;;
    *) config_path="$HOME/.config/starship.toml" ;;
  esac

  if [[ -r "$config_path" ]]; then
    export STARSHIP_CONFIG="$config_path"
  else
    export STARSHIP_CONFIG="$HOME/.config/starship.toml"
  fi
}

_set_starship_config_for_theme "$NVIM_THEME"

_sync_theme_from_state() {
  [[ -r "$THEME_STATE_FILE" ]] || return 0
  local saved
  saved="$(<"$THEME_STATE_FILE")"
  case "$saved" in
    sakura_night|ashfall|rosepine)
      if [[ "$saved" != "$NVIM_THEME" ]]; then
        export NVIM_THEME="$saved"
        _set_starship_config_for_theme "$NVIM_THEME"
      fi
      ;;
  esac
}

theme() {
  local next="$1"
  if [[ -z "$next" ]]; then
    echo "Current theme: $NVIM_THEME"
    echo "Usage: theme <sakura_night|ashfall|rosepine>"
    return 0
  fi

  case "$next" in
    sakura_night|ashfall|rosepine) ;;
    *)
      echo "Invalid theme: $next"
      echo "Valid themes: sakura_night ashfall rosepine"
      return 1
      ;;
  esac

  export NVIM_THEME="$next"
  _set_starship_config_for_theme "$NVIM_THEME"
  mkdir -p "$THEME_STATE_DIR"
  printf '%s\n' "$next" > "$THEME_STATE_FILE"
  echo "Theme set to $next"
}

autoload -Uz add-zsh-hook
add-zsh-hook precmd _sync_theme_from_state

# Aliases
alias la='eza --long --all --git --no-user --icons=auto'
alias l='eza --long --git --no-user --icons=auto'
alias where='find . -name'
alias gd='git diff'
alias gs='git status'
alias gb='git branch'

if command -v fzf >/dev/null 2>&1; then
  source <(fzf --zsh)
fi
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"  # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"  # This loads nvm bash_completion
[[ -s "$HOME/.local/bin/env" ]] && source "$HOME/.local/bin/env"

# pnpm
export PNPM_HOME="/Users/ryancaldwell/Library/pnpm"
case ":$PATH:" in
  *":$PNPM_HOME:"*) ;;
  *) export PATH="$PNPM_HOME:$PATH" ;;
esac
# pnpm end

export EDITOR='nvim'
[[ -s /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh ]] && \
  source /opt/homebrew/share/zsh-autosuggestions/zsh-autosuggestions.zsh
[[ -s /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh ]] && \
  source /opt/homebrew/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh
eval "$(starship init zsh)"

# Load in secrets if the file exists
[[ -f ~/.secrets ]] && source ~/.secrets

# Git Worktree Manager (managed via .chezmoiexternal.toml)
WT_COPY_SENSITIVE_DOTFILES=1
[[ -f "$HOME/.config/wt/wt.zsh" ]] && source "$HOME/.config/wt/wt.zsh"

# zoxide for easy `cd`ing (keep at end to avoid doctor warning)
eval "$(zoxide init --cmd cd zsh)"
